# Backend auth service (server-side only, not exposed to browser)
AUTH_URL=http://localhost:8080

# JWT public key (PEM-encoded RSA public key — verification only, cannot sign)
JWT_PUBLIC_KEY=

# JWT cookie name
SESSION_COOKIE=pc_session

# SQLite database path
DATABASE_PATH=./data/dashboard.db

# Resend (for inbox email forwarding)
RESEND_API_KEY=re_xxx
EMAIL_FROM=Public Charity <notify@public.charity>

# API key for external message injection (AI agent)
DASHBOARD_API_KEY=
